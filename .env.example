# ==========================================
# Billwise API — Variables de entorno
# Copia este archivo a .env y completa los valores
# NUNCA commitear el .env real al repositorio
# ==========================================

# Base de datos (Docker)
DB_USER=postgres
DB_PASSWORD=billwise_secret
DB_NAME=billwise_dev
DB_PORT=5433

# JWT — genera con: make gen-jwt
JWT_SECRET=cambia-esto-por-un-secret-seguro-de-al-menos-256-bits-longitud-minima

# Superadmin por defecto (se crea al primer arranque si no existe)
SUPERADMIN_EMAIL=admin@billwise.com
SUPERADMIN_PASSWORD=Admin1234!
SUPERADMIN_NAME=Super Admin

# Claude API (Sprint 3)
CLAUDE_API_KEY=

# AWS S3 / Cloudflare R2 (Sprint 4)
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=billwise-files
STORAGE_ENDPOINT=

# Solo producción
DATABASE_URL=jdbc:postgresql://host:5432/billwise_prod
